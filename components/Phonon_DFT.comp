/*******************************************************************************
*
*  McStas, neutron ray-tracing package
*  Copyright(C) 2025
*
* %I
* Written by: Adrian / Claude (AI-assisted)
* Date: 2025
* Version: 1.0b
* Origin: TUM
*
* A sample component for phonon and Bragg scattering from DFT-calculated
* dispersions and CIF-derived structure factors.
*
* %D
* Phase 1b: Bragg scattering kernel with incoherent channel.
* Reads a CIF or LAU/LAZ reflection file (via cif2hkl) and scatters
* neutrons elastically from Bragg reflections using a simplified Ewald
* sphere model with Gaussian mosaic (delta_d_d).
*
* This component is designed as the foundation for a "universal sample"
* that will later incorporate phonon scattering from DFT dispersion grids,
* multi-BZ intensity variation, and magnetic excitations.
*
* The Bragg model is intentionally simpler than Single_crystal: we use
* a single isotropic delta_d_d mosaic width rather than the full
* anisotropic mosaic + Ewald tangent plane + Cholesky decomposition.
* For precise mosaic modeling, use Single_crystal directly.
*
* Sample shape: cylinder, box, or sphere.
*
* Algorithm (Bragg channel):
*   1. Intersect neutron with sample geometry
*   2. Compute ki, find all reflections within Ewald sphere proximity
*   3. Choose channel: Bragg vs incoherent (vs phonon in future)
*   4. If Bragg: select reflection weighted by F2, compute kf = ki - tau
*   5. Apply mosaic perturbation, normalize |kf| = |ki| (elastic)
*   6. Compute weight corrections (absorption, cross section, path length)
*
* %P
* INPUT PARAMETERS:
* radius: [m]            Outer radius of cylindrical sample
* yheight: [m]           Height of sample
* xwidth: [m]            Width of box sample
* zdepth: [m]            Depth of box sample
* reflections: [string]  CIF, LAU, or LAZ reflection file (or "" for incoherent only)
* sigma_abs: [barns]     Absorption cross section per unit cell at 2200 m/s
* sigma_inc: [barns]     Incoherent scattering cross section per unit cell
* a: [AA]                Lattice parameter a
* b: [AA]                Lattice parameter b (default = a)
* c: [AA]                Lattice parameter c (default = a)
* alpha: [deg]           Lattice angle alpha (default = 90)
* beta: [deg]            Lattice angle beta (default = 90)
* gamma_l: [deg]         Lattice angle gamma (default = 90) ('gamma_l' to avoid conflict with McStas 'gamma')
* ax: [AA]               Direct lattice vector a, x-component (overrides a,b,c if set)
* ay: [AA]               Direct lattice vector a, y-component
* az: [AA]               Direct lattice vector a, z-component
* bx: [AA]               Direct lattice vector b, x-component
* by: [AA]               Direct lattice vector b, y-component
* bz_l: [AA]             Direct lattice vector b, z-component ('bz_l' avoids conflict)
* cx: [AA]               Direct lattice vector c, x-component
* cy: [AA]               Direct lattice vector c, y-component
* cz: [AA]               Direct lattice vector c, z-component
* delta_d_d: [1]         Relative d-spacing width (Gaussian RMS), for mosaic broadening
* barns: [1]             Flag: 1 if F2 is in barns (laz files), 0 if in fm^2 (lau files)
* debye_waller: [1]      Global Debye-Waller factor (1 = no DW correction)
* T: [K]                 Temperature (for future phonon Bose factor; currently unused)
* p_interact: [1]        MC probability for scattering (remainder is transmission)
* target_x: [m]          Focusing target x
* target_y: [m]          Focusing target y
* target_z: [m]          Focusing target z
* target_index: [1]      Relative index of component to focus at
* phonon_gamma: [meV]    Intrinsic phonon linewidth Gamma (Lorentzian FWHM). 0=delta function (root-finding), >0=Lorentzian spectral function. Per-point Gamma from column 7 of dispersion file overrides this value when present.
*
* OUTPUT PARAMETERS:
* (none - scattering modifies the neutron state in-place via SCATTER/ABSORB)
*
* %L
* Designed for combined elastic/inelastic scattering. Phonon kernel coming in Phase 1a.
*
* %E
******************************************************************************/

DEFINE COMPONENT Phonon_DFT

SETTING PARAMETERS (
  string reflections="NULL",
  string dispersion="NULL",
  radius=0, yheight=0, xwidth=0, zdepth=0,
  sigma_abs=0, sigma_inc=0,
  a=0, b=0, c=0, alpha=90, beta=90, gamma_l=90,
  ax=0, ay=0, az=0,
  bx=0, by=0, bz_l=0,
  cx=0, cy=0, cz=0,
  delta_d_d=1e-4, barns=1, debye_waller=1, T=300,
  p_interact=0.8,
  p_phonon=0.5,
  phonon_gamma=0,
  int tessellate=1,
  int phonon_e_steps=50,
  target_x=0, target_y=0, target_z=0,
  target_index=0,
  focus_r=0, focus_xw=0, focus_yh=0,
  focus_aw=0, focus_ah=0
)

SHARE
%{
%include "read_table-lib"

/* MSVC compatibility: map POSIX names to Windows equivalents */
#ifdef _MSC_VER
  #define strcasecmp _stricmp
  #define unlink _unlink
  #define close _close
#endif

#ifndef PHONON_DFT_DECL
#define PHONON_DFT_DECL

/* Maximum number of reflections that can be active simultaneously */
#define PDFT_MAX_TAU 256

/* ======================================================================
   Bragg reflection data (one per hkl)
   ====================================================================== */
typedef struct {
  int    h, k, l;
  double F2;                     /* |F|^2 in barns (or fm^2, see flag_barns) */
  double tau_x, tau_y, tau_z;    /* Reciprocal lattice point in AA^-1 */
  double tau;                    /* |tau| */
} pdft_bragg_refl;

/* Active reflection near Ewald sphere (runtime, per-neutron) */
typedef struct {
  int    index;     /* index into bragg_refl array */
  double refl;      /* scattering probability for this reflection */
  double xsect;     /* refl * F2 */
} pdft_tau_data;

/* ======================================================================
   Lattice / reciprocal space info
   ====================================================================== */
typedef struct {
  /* Direct space lattice vectors (AA) */
  double m_ax, m_ay, m_az;
  double m_bx, m_by, m_bz;
  double m_cx, m_cy, m_cz;
  /* Reciprocal space lattice vectors (AA^-1), include 2*PI */
  double asx, asy, asz;
  double bsx, bsy, bsz;
  double csx, csy, csz;
  /* Unit cell volume (AA^3) */
  double V0;
} pdft_lattice;

/* ======================================================================
   PHONON KERNEL: typedefs needed before pdft_info
   ====================================================================== */

/* Maximum number of phonon branches */
#define PDFT_MAX_BRANCHES 64

/* Maximum number of phonon solutions (branches * 2 for Stokes/anti-Stokes) */
#define PDFT_MAX_PHONON_ROOTS 128

/* Phonon dispersion grid: regular grid in r.l.u., per-branch E and I */
typedef struct {
  int nx, ny, nz;           /* grid dimensions (number of nodes per axis) */
  int num_branches;          /* number of phonon branches */
  
  /* Flattened 4D arrays: index = ((ix*ny + iy)*nz + iz)*num_branches + b */
  double *E_data;            /* energy at each grid node, per branch (meV) */
  double *I_data;            /* intensity at each grid node, per branch */
  double *G_data;            /* linewidth Gamma at each grid node, per branch (meV FWHM), NULL if not in file */
  
  /* Grid range in r.l.u. (as given in file, not necessarily [-0.5,0.5]) */
  double H_min, H_max;
  double K_min, K_max;
  double L_min, L_max;
  
  /* Grid spacing */
  double dH, dK, dL;
  
  /* BZ extent (= max - min, used for tessellation) */
  double H_span, K_span, L_span;
  
  /* Maximum phonon energy across all branches (meV) */
  double E_max;
  
  /* Whether data was loaded */
  int loaded;
} pdft_phonon_grid;

/* A single phonon scattering solution */
typedef struct {
  double v_f;         /* final neutron speed */
  double omega;       /* energy transfer (meV), positive = neutron loses energy */
  double intensity;   /* interpolated scattering weight */
  int    branch;      /* branch index */
} pdft_phonon_root;

/* ======================================================================
   Main info struct for the component instance
   ====================================================================== */
typedef struct {
  pdft_lattice lattice;
  
  /* Bragg reflections */
  pdft_bragg_refl *bragg_list;
  int    bragg_count;
  int    flag_barns;
  
  /* Phonon dispersion grid */
  pdft_phonon_grid phonon_grid;
  
  /* Material properties */
  double sigma_a;   /* absorption cross section per unit cell at 2200 m/s */
  double sigma_i;   /* incoherent cross section per unit cell */
  double DW;        /* Debye-Waller factor */
  
  /* Geometry */
  int shape;        /* 0:cylinder, 1:box, 2:sphere */
  
  /* Diagnostics */
  int flag_warning;
} pdft_info;

/* ======================================================================
   Lattice computation: angles+lengths → vectors → reciprocal
   Follows Single_crystal convention.
   ====================================================================== */
void pdft_compute_lattice(pdft_lattice *lat,
                          double a, double b, double c,
                          double aa, double bb, double cc,
                          double ax, double ay, double az,
                          double bx, double by, double bz,
                          double cx, double cy, double cz)
{
  double tmp_x, tmp_y, tmp_z;
  double sin_cc, cx_sq;
  
  /* If lattice vectors are given directly, use them */
  if (ax || ay || az || bx || by || bz || cx || cy || cz) {
    lat->m_ax = ax; lat->m_ay = ay; lat->m_az = az;
    lat->m_bx = bx; lat->m_by = by; lat->m_bz = bz;
    lat->m_cx = cx; lat->m_cy = cy; lat->m_cz = cz;
  }
  /* Otherwise compute from lengths + angles */
  else if (a > 0) {
    if (b <= 0) b = a;
    if (c <= 0) c = a;
    /* Convention: a along x, b in xz-plane, c has y-component.
       This puts a* and b* in the horizontal scattering plane (xz)
       and c* along the vertical (y), so the (H,K,0) plane is 
       directly accessible to a TAS.  Differs from Single_crystal
       which uses b along z, a in yz-plane. */
    sin_cc = sin(cc*DEG2RAD);
    if (fabs(sin_cc) < 1e-10) {
      fprintf(stderr, "Phonon_DFT: ERROR: Lattice angle gamma=%g degrees is degenerate!\n", cc);
      exit(-1);
    }
    lat->m_ax = a;          lat->m_ay = 0;          lat->m_az = 0;
    lat->m_bx = b*cos(cc*DEG2RAD);  lat->m_by = 0;  lat->m_bz = b*sin_cc;
    lat->m_cx = c*cos(bb*DEG2RAD);
    lat->m_cz = c*(cos(aa*DEG2RAD) - cos(cc*DEG2RAD)*cos(bb*DEG2RAD)) / sin_cc;
    cx_sq = c*c - lat->m_cx*lat->m_cx - lat->m_cz*lat->m_cz;
    lat->m_cy = (cx_sq > 0) ? sqrt(cx_sq) : 0;
  } else {
    fprintf(stderr, "Phonon_DFT: ERROR: No lattice parameters specified!\n");
    exit(-1);
  }
  
  /* Compute reciprocal lattice vectors: a* = 2*PI * (b x c) / V0 */
  /* V0 = a . (b x c) */
  vec_prod(tmp_x, tmp_y, tmp_z,
           lat->m_bx, lat->m_by, lat->m_bz,
           lat->m_cx, lat->m_cy, lat->m_cz);
  lat->V0 = fabs(scalar_prod(lat->m_ax, lat->m_ay, lat->m_az,
                              tmp_x, tmp_y, tmp_z));
  
  if (lat->V0 <= 0) {
    fprintf(stderr, "Phonon_DFT: ERROR: Unit cell volume is zero or negative!\n");
    exit(-1);
  }
  
  lat->asx = 2*PI/lat->V0 * tmp_x;
  lat->asy = 2*PI/lat->V0 * tmp_y;
  lat->asz = 2*PI/lat->V0 * tmp_z;
  
  vec_prod(tmp_x, tmp_y, tmp_z,
           lat->m_cx, lat->m_cy, lat->m_cz,
           lat->m_ax, lat->m_ay, lat->m_az);
  lat->bsx = 2*PI/lat->V0 * tmp_x;
  lat->bsy = 2*PI/lat->V0 * tmp_y;
  lat->bsz = 2*PI/lat->V0 * tmp_z;
  
  vec_prod(tmp_x, tmp_y, tmp_z,
           lat->m_ax, lat->m_ay, lat->m_az,
           lat->m_bx, lat->m_by, lat->m_bz);
  lat->csx = 2*PI/lat->V0 * tmp_x;
  lat->csy = 2*PI/lat->V0 * tmp_y;
  lat->csz = 2*PI/lat->V0 * tmp_z;
}

/* ======================================================================
   Read Bragg reflections from file (CIF/LAU/LAZ via cif2hkl)
   Simplified version of Single_crystal's read_hkl_data
   ====================================================================== */

#ifndef CIF2HKL
#define CIF2HKL

/* Validate filename contains no shell metacharacters.
   Returns 1 if safe, 0 if potentially dangerous. */
static int pdft_filename_is_safe(const char *path) {
  const char *p;
  if (!path) return 0;
  for (p = path; *p; p++) {
    /* Reject characters that could be used for shell injection.
       Note: backslash is the path separator on Windows, so we
       must allow it there. On Unix it's an escape character but
       is extremely rare in real filenames from Open_File(). */
    if (*p == ';' || *p == '|' || *p == '&' || *p == '$' ||
        *p == '`' || *p == '\'' || *p == '"' ||
#ifndef _WIN32
        *p == '\\' ||
#endif
        *p == '\n' || *p == '\r' || *p == '(' || *p == ')' ||
        *p == '{' || *p == '}' || *p == '<' || *p == '>') {
      return 0;
    }
  }
  return 1;
}

char *cif2hkl(char *infile, char *options) {
  char cmd[1024];
  int  ret = 0;
  int  found = 0;
  char *OUTFILE;
  char *inpath;
  FILE *f_infile;
  FILE *file;
  const char *ext;
  
  ext = strrchr(infile, '.');
  if (!ext || ext == infile) return infile;
  else ext++;
  
  if (strcasecmp(ext, "cif")
      && strcasecmp(ext, "pcr")
      && strcasecmp(ext, "cfl")
      && strcasecmp(ext, "shx")
      && strcasecmp(ext, "ins")
      && strcasecmp(ext, "res")) return infile;
  
  OUTFILE = malloc(1024);
  if (!OUTFILE) return infile;
  inpath = malloc(1024);
  if (!inpath) { free(OUTFILE); return infile; }

  f_infile = Open_File(infile, "r", inpath);
  if (!f_infile) { free(OUTFILE); free(inpath); return infile; }
  fclose(f_infile);
  
  /* Validate filenames before passing to system() */
  if (!pdft_filename_is_safe(inpath)) {
    fprintf(stderr, "Phonon_DFT: ERROR: Filename contains unsafe characters: %s\n", inpath);
    free(OUTFILE); free(inpath);
    return NULL;
  }
  
  /* Create a temporary filename (cross-platform: works on Windows and Linux) */
  {
    char *tmp = tmpnam(NULL);
    if (!tmp) {
      fprintf(stderr, "Phonon_DFT: ERROR: Could not create temporary filename\n");
      free(OUTFILE); free(inpath);
      return NULL;
    }
    strncpy(OUTFILE, tmp, 1023);
    OUTFILE[1023] = '\0';
  }
  
  if (!found && getenv("CIF2HKL")) {
    snprintf(cmd, 1024, "%s -o %s %s %s",
             getenv("CIF2HKL"), OUTFILE, options, inpath);
    ret = system(cmd);
    if (ret != -1 && ret != 127) found = 1;
  }
  if (!found) {
    snprintf(cmd, 1024, "%s -o %s %s %s",
             "cif2hkl", OUTFILE, options, inpath);
    ret = system(cmd);
    if (ret != -1 && ret != 127) found = 1;
  }
  if (!found) {
    snprintf(cmd, 1024, "%s%c%s%c%s -o %s %s %s",
             getenv(FLAVOR_UPPER) ? getenv(FLAVOR_UPPER) : MCSTAS,
             MC_PATHSEP_C, "bin", MC_PATHSEP_C, "cif2hkl",
             OUTFILE, options, inpath);
    ret = system(cmd);
  }
  if (ret == -1 || ret == 127) {
    fprintf(stderr, "Phonon_DFT: ERROR: cif2hkl tool not found. "
            "Convert CIF to LAZ/LAU format manually, or install cif2hkl.\n");
    free(OUTFILE); free(inpath); return NULL;
  }
  
  file = fopen(OUTFILE, "r");
  if (!file) {
    fprintf(stderr, "Phonon_DFT: ERROR: cif2hkl failed to produce output for %s "
            "(exit code %d). Check that cif2hkl and its dependencies (libgfortran) "
            "are installed correctly, or use a pre-converted LAZ/LAU file.\n",
            inpath, ret);
    free(OUTFILE); free(inpath); return NULL;
  }
  MPI_MASTER(
    printf("Phonon_DFT: Converting %s into F2(HKL) list %s\n", inpath, OUTFILE);
  );
  fclose(file);
  free(inpath);  /* inpath no longer needed after this point */
  return OUTFILE;
}
#endif /* CIF2HKL */

int pdft_read_bragg(char *SC_file, pdft_info *info)
{
  t_Table sTable;
  int i, size, count;
  char **parsing;
  char *filename = NULL;
  int col_h = 1, col_k = 2, col_l = 3, col_F = 0, col_F2 = 0;
  pdft_lattice *lat;
  double file_a, file_b, file_c;
  double file_aa, file_bb, file_cc;
  double h, k, l, F2, F_val;
  pdft_bragg_refl sort_tmp;
  int sort_j;
  
  lat = &(info->lattice);
  
  if (!SC_file || !strlen(SC_file) || !strcmp(SC_file, "NULL") || !strcmp(SC_file, "0")) {
    info->bragg_count = 0;
    return 0;
  }
  
  filename = cif2hkl(SC_file, "--xtal --mode NUC");
  if (!filename) {
    fprintf(stderr, "Phonon_DFT: ERROR: cif2hkl conversion failed for %s\n", SC_file);
    return -1;
  }
  if (filename != SC_file) info->flag_barns = 1; /* cif2hkl returns barns */
  
  if (Table_Read(&sTable, filename, 1) <= 0) {
    fprintf(stderr, "Phonon_DFT: ERROR: Could not read file %s\n", SC_file);
    return -1;
  }
  
  /* Parse header for metadata */
  parsing = Table_ParseHeader(sTable.header,
    "sigma_abs", "sigma_a ",
    "sigma_inc", "sigma_i ",
    "column_h", "column_k", "column_l",
    "column_F ", "column_F2",
    "lattice_a ", "lattice_b ", "lattice_c ",
    "lattice_aa", "lattice_bb", "lattice_cc",
    "Vc",
    NULL);
  
  if (parsing) {
    if (parsing[0] && !info->sigma_a)  info->sigma_a  = atof(parsing[0]);
    if (parsing[1] && !info->sigma_a)  info->sigma_a  = atof(parsing[1]);
    if (parsing[2] && !info->sigma_i)  info->sigma_i  = atof(parsing[2]);
    if (parsing[3] && !info->sigma_i)  info->sigma_i  = atof(parsing[3]);
    if (parsing[4])  col_h  = atoi(parsing[4]);
    if (parsing[5])  col_k  = atoi(parsing[5]);
    if (parsing[6])  col_l  = atoi(parsing[6]);
    if (parsing[7])  col_F  = atoi(parsing[7]);
    if (parsing[8])  col_F2 = atoi(parsing[8]);
    /* Lattice parameters from file (only if not already set by user) */
    file_a = 0; file_b = 0; file_c = 0;
    file_aa = 0; file_bb = 0; file_cc = 0;
    if (parsing[9])  file_a  = atof(parsing[9]);
    if (parsing[10]) file_b  = atof(parsing[10]);
    if (parsing[11]) file_c  = atof(parsing[11]);
    if (parsing[12]) file_aa = atof(parsing[12]);
    if (parsing[13]) file_bb = atof(parsing[13]);
    if (parsing[14]) file_cc = atof(parsing[14]);
    if (parsing[15] && lat->V0 <= 0) lat->V0 = atof(parsing[15]);
    
    /* If user hasn't set lattice and file has it, recompute */
    if (file_a > 0 && lat->V0 <= 0) {
      if (file_b <= 0) file_b = file_a;
      if (file_c <= 0) file_c = file_a;
      if (file_aa <= 0) file_aa = 90;
      if (file_bb <= 0) file_bb = 90;
      if (file_cc <= 0) file_cc = 90;
      pdft_compute_lattice(lat, file_a, file_b, file_c,
                           file_aa, file_bb, file_cc,
                           0, 0, 0, 0, 0, 0, 0, 0, 0);
      MPI_MASTER(
        printf("Phonon_DFT: Lattice from file: a=%g b=%g c=%g  V0=%g AA^3\n",
               file_a, file_b, file_c, lat->V0);
      );
    }
    
    for (i = 0; i <= 15; i++) if (parsing[i]) free(parsing[i]);
    free(parsing);
  }
  
  if (lat->V0 <= 0) {
    fprintf(stderr, "Phonon_DFT: ERROR: No unit cell volume! Provide lattice parameters.\n");
    Table_Free(&sTable);
    return -1;
  }
  
  size = sTable.rows;
  if (!size) {
    fprintf(stderr, "Phonon_DFT: ERROR: No reflections in %s\n", SC_file);
    Table_Free(&sTable);
    return -1;
  }
  
  info->bragg_list = (pdft_bragg_refl *)malloc(size * sizeof(pdft_bragg_refl));
  if (!info->bragg_list) {
    fprintf(stderr, "Phonon_DFT: ERROR: Memory allocation failed for reflections\n");
    Table_Free(&sTable);
    return -1;
  }
  
  count = 0;
  for (i = 0; i < size; i++) {
    h = Table_Index(sTable, i, col_h - 1);
    k = Table_Index(sTable, i, col_k - 1);
    l = Table_Index(sTable, i, col_l - 1);
    
    if (col_F2) {
      F2 = Table_Index(sTable, i, col_F2 - 1);
    } else if (col_F) {
      F_val = Table_Index(sTable, i, col_F - 1);
      F2 = F_val * F_val;
    } else {
      /* Neither column_F nor column_F2 specified in header;
         try column 7 as default F2 (Crystallographica format) */
      if (sTable.columns >= 7)
        F2 = Table_Index(sTable, i, 6);
      else if (sTable.columns >= 4)
        F2 = Table_Index(sTable, i, 3);  /* column 4 as fallback */
      else
        F2 = 0;
    }
    
    if (F2 <= 0) continue;  /* skip zero-intensity reflections */
    
    info->bragg_list[count].h = (int)h;
    info->bragg_list[count].k = (int)k;
    info->bragg_list[count].l = (int)l;
    info->bragg_list[count].F2 = F2;
    
    /* Compute tau = h*a* + k*b* + l*c* in AA^-1 */
    info->bragg_list[count].tau_x = h * lat->asx + k * lat->bsx + l * lat->csx;
    info->bragg_list[count].tau_y = h * lat->asy + k * lat->bsy + l * lat->csy;
    info->bragg_list[count].tau_z = h * lat->asz + k * lat->bsz + l * lat->csz;
    info->bragg_list[count].tau = sqrt(
      info->bragg_list[count].tau_x * info->bragg_list[count].tau_x +
      info->bragg_list[count].tau_y * info->bragg_list[count].tau_y +
      info->bragg_list[count].tau_z * info->bragg_list[count].tau_z);
    
    count++;
  }
  
  info->bragg_count = count;
  
  /* Sort by |tau| for early termination in Ewald search */
  /* Simple insertion sort is fine for a few hundred reflections */
  for (i = 1; i < count; i++) {
    sort_tmp = info->bragg_list[i];
    sort_j = i - 1;
    while (sort_j >= 0 && info->bragg_list[sort_j].tau > sort_tmp.tau) {
      info->bragg_list[sort_j + 1] = info->bragg_list[sort_j];
      sort_j--;
    }
    info->bragg_list[sort_j + 1] = sort_tmp;
  }
  
  Table_Free(&sTable);
  
  /* Clean up temporary cif2hkl output */
  if (filename != SC_file) {
    unlink(filename);
    free(filename);
  }
  
  return count;
}

/* ======================================================================
   Bragg search: find reflections near the Ewald sphere
   
   Simplified version of Single_crystal's hkl_search.
   Instead of the full tangent-plane + Cholesky model, we use a simple
   Gaussian cutoff in |tau| - 2*ki*sin(theta)| space, parameterized
   by delta_d_d.
   
   Returns: number of active reflections (tau_count)
   Updates: coh_refl (total reflection probability), coh_xsect (total F2-weighted)
   ====================================================================== */
#ifndef _MSC_VER
#pragma acc routine
#endif
int pdft_bragg_search(pdft_bragg_refl *L, pdft_tau_data *tlist,
                      int count, double V0,
                      double kix, double kiy, double kiz,
                      double delta_d_d,
                      double *coh_refl, double *coh_xsect)
{
  double ki, denom, tau_max;
  int j, i;
  double rho_x, rho_y, rho_z, rho, diff, sigma_tau, w;
  
  ki = sqrt(kix*kix + kiy*kiy + kiz*kiz);
  denom = 1 - 5 * delta_d_d;
  tau_max = (denom > 0.01) ? (2 * ki / denom) : (200 * ki);  /* clamp for large delta_d_d */
  j = 0;
  
  *coh_refl = 0;
  *coh_xsect = 0;
  
  for (i = 0; i < count; i++) {
    if (L[i].tau > tau_max) break;  /* sorted by tau, so we can stop */
    
    /* Vector from reciprocal lattice point to tip of ki: rho = ki - tau */
    rho_x = kix - L[i].tau_x;
    rho_y = kiy - L[i].tau_y;
    rho_z = kiz - L[i].tau_z;
    rho = sqrt(rho_x*rho_x + rho_y*rho_y + rho_z*rho_z);
    
    /* For elastic scattering, |kf| = |ki|, so |rho| should equal |ki|.
       The deviation from the Ewald sphere is |rho| - ki. */
    diff = fabs(rho - ki);
    
    /* Gaussian mosaic width in reciprocal space: sigma = delta_d_d * |tau| */
    sigma_tau = delta_d_d * L[i].tau;
    if (sigma_tau <= 0) continue;
    
    /* Gaussian cutoff at 5 sigma */
    if (diff > 5 * sigma_tau) continue;
    
    /* Gaussian weight */
    w = exp(-0.5 * diff * diff / (sigma_tau * sigma_tau));
    
    /* Cross-section factor (simplified from Single_crystal) */
    tlist[j].index = i;
    tlist[j].refl = w / (V0 * ki * ki * sigma_tau);
    tlist[j].xsect = tlist[j].refl * L[i].F2;
    *coh_refl += tlist[j].refl;
    *coh_xsect += tlist[j].xsect;
    j++;
    
    if (j >= PDFT_MAX_TAU) break;  /* safety limit */
  }
  
  return j;
}

/* ======================================================================
   PHONON KERNEL: dispersion grid data structures and functions
   ====================================================================== */

/* Kelvin to meV conversion */
#define PDFT_T2E (1.0/11.605)

/* ======================================================================
   Bose factor: n(omega, T) 
   For omega > 0 (Stokes, neutron loses energy): n+1
   For omega < 0 (anti-Stokes, neutron gains energy): n
   ====================================================================== */
double pdft_nbose(double omega, double temp)
{
  double nb, arg;
  if (temp <= 0) return (omega > 0) ? 1.0 : 0.0;
  if (fabs(omega) < 1e-10) return temp * PDFT_T2E / fabs(omega + 1e-20);
  arg = fabs(omega) / (temp * PDFT_T2E);
  if (arg > 700) {
    /* Avoid exp overflow: at high E/T, n->0 for anti-Stokes, n+1->1 for Stokes */
    return (omega > 0) ? 1.0 : 0.0;
  }
  nb = (omega > 0) 
    ? 1.0 + 1.0 / (exp(arg) - 1.0)
    : 1.0 / (exp(arg) - 1.0);
  return nb;
}

/* ======================================================================
   Read phonon dispersion grid from file
   
   File format: columnar text, one row per (q-point, branch):
     H(rlu) K(rlu) L(rlu) E(meV) Intensity Branch
   
   Header keywords (optional):
     # grid_nx <int>
     # grid_ny <int>
     # grid_nz <int>
     # num_branches <int>
   
   If grid dimensions are not in the header, they are auto-detected
   from the unique sorted values in each column.
   ====================================================================== */
int pdft_read_phonon_grid(char *filename, pdft_phonon_grid *grid)
{
  t_Table sTable;
  int i, total_rows;
  int nx_detected, ny_detected, nz_detected, nb_detected;
  int ix, iy, iz, ib, flat_idx;
  double h_val, k_val, l_val, e_val, i_val;
  int b_val;
  double g_val;
  int has_gamma;
  char **parsing;
  double fH, fK, fL;
  /* For auto-detection of grid dimensions */
  double prev_h, prev_k, prev_l;
  int count_h, count_k, count_l, max_branch;
  
  if (!filename || !strlen(filename) || !strcmp(filename, "NULL") || !strcmp(filename, "0")) {
    grid->loaded = 0;
    return 0;
  }
  
  if (Table_Read(&sTable, filename, 1) <= 0) {
    fprintf(stderr, "Phonon_DFT: ERROR: Could not read phonon file %s\n", filename);
    return -1;
  }
  
  total_rows = sTable.rows;
  if (total_rows < 2) {
    fprintf(stderr, "Phonon_DFT: ERROR: Phonon file %s has too few rows (%d)\n",
            filename, total_rows);
    Table_Free(&sTable);
    return -1;
  }
  if (sTable.columns < 6) {
    fprintf(stderr, "Phonon_DFT: ERROR: Phonon file %s needs >= 6 columns "
            "(H K L E Intensity Branch), got %d\n", filename, (int)sTable.columns);
    Table_Free(&sTable);
    return -1;
  }
  
  /* Parse header for grid dimensions */
  nx_detected = 0; ny_detected = 0; nz_detected = 0; nb_detected = 0;
  parsing = Table_ParseHeader(sTable.header,
    "grid_nx", "grid_ny", "grid_nz", "num_branches",
    NULL);
  if (parsing) {
    if (parsing[0]) nx_detected = atoi(parsing[0]);
    if (parsing[1]) ny_detected = atoi(parsing[1]);
    if (parsing[2]) nz_detected = atoi(parsing[2]);
    if (parsing[3]) nb_detected = atoi(parsing[3]);
    for (i = 0; i <= 3; i++) if (parsing[i]) free(parsing[i]);
    free(parsing);
  }
  
  /* Auto-detect grid dimensions if not in header.
     Strategy: scan the data sorted by H,K,L to count unique values.
     Assumes the file is ordered: branch varies fastest, then L, then K, then H.
     (This is the natural order from Phonopy/Euphonic mesh output.) */
  if (!nb_detected) {
    max_branch = 0;
    for (i = 0; i < total_rows; i++) {
      b_val = (int)Table_Index(sTable, i, 5);
      if (b_val > max_branch) max_branch = b_val;
    }
    nb_detected = max_branch + 1;  /* 0-indexed */
  }
  
  if (!nx_detected || !ny_detected || !nz_detected) {
    /* Count unique H values (assumes data sorted by H first) */
    count_h = 1;
    prev_h = Table_Index(sTable, 0, 0);
    for (i = nb_detected; i < total_rows; i += nb_detected) {
      h_val = Table_Index(sTable, i, 0);
      if (fabs(h_val - prev_h) > 1e-8) {
        count_h++;
        prev_h = h_val;
      }
    }
    /* Total grid points = total_rows / num_branches */
    /* nz = total / (nx * ny * nb), but we need to figure out ny too */
    /* Count unique K values for the first H slice */
    count_k = 1;
    prev_k = Table_Index(sTable, 0, 1);
    for (i = nb_detected; i < total_rows; i += nb_detected) {
      h_val = Table_Index(sTable, i, 0);
      if (fabs(h_val - Table_Index(sTable, 0, 0)) > 1e-8) break;
      k_val = Table_Index(sTable, i, 1);
      if (fabs(k_val - prev_k) > 1e-8) {
        count_k++;
        prev_k = k_val;
      }
    }
    /* Count unique L values for first H,K slice */
    count_l = 1;
    prev_l = Table_Index(sTable, 0, 2);
    for (i = nb_detected; i < total_rows; i += nb_detected) {
      h_val = Table_Index(sTable, i, 0);
      k_val = Table_Index(sTable, i, 1);
      if (fabs(h_val - Table_Index(sTable, 0, 0)) > 1e-8) break;
      if (fabs(k_val - Table_Index(sTable, 0, 1)) > 1e-8) break;
      l_val = Table_Index(sTable, i, 2);
      if (fabs(l_val - prev_l) > 1e-8) {
        count_l++;
        prev_l = l_val;
      }
    }
    
    if (!nx_detected) nx_detected = count_h;
    if (!ny_detected) ny_detected = count_k;
    if (!nz_detected) nz_detected = count_l;
  }
  
  /* Validate */
  if (nx_detected * ny_detected * nz_detected * nb_detected != total_rows) {
    fprintf(stderr, "Phonon_DFT: WARNING: Grid dimensions %d x %d x %d x %d branches = %d "
            "!= %d rows in file. Attempting to proceed anyway.\n",
            nx_detected, ny_detected, nz_detected, nb_detected,
            nx_detected * ny_detected * nz_detected * nb_detected, total_rows);
  }
  
  grid->nx = nx_detected;
  grid->ny = ny_detected;
  grid->nz = nz_detected;
  grid->num_branches = nb_detected;
  
  MPI_MASTER(
    printf("Phonon_DFT: Phonon grid: %d x %d x %d, %d branches, %d total rows\n",
           grid->nx, grid->ny, grid->nz, grid->num_branches, total_rows);
  );
  
  /* Allocate grid arrays */
  grid->E_data = (double *)calloc(nx_detected * ny_detected * nz_detected * nb_detected, sizeof(double));
  grid->I_data = (double *)calloc(nx_detected * ny_detected * nz_detected * nb_detected, sizeof(double));
  if (!grid->E_data || !grid->I_data) {
    fprintf(stderr, "Phonon_DFT: ERROR: Memory allocation failed for phonon grid\n");
    Table_Free(&sTable);
    return -1;
  }
  
  /* Allocate per-point linewidth array if column 7 (Gamma) is present */
  has_gamma = (sTable.columns >= 7);
  grid->G_data = NULL;
  if (has_gamma) {
    grid->G_data = (double *)calloc(nx_detected * ny_detected * nz_detected * nb_detected, sizeof(double));
    if (!grid->G_data) {
      fprintf(stderr, "Phonon_DFT: WARNING: Memory allocation failed for Gamma grid, using global fallback\n");
      has_gamma = 0;
    } else {
      MPI_MASTER(
        printf("Phonon_DFT: Column 7 detected: reading per-point linewidth Gamma (meV FWHM)\n");
      );
    }
  }
  
  /* Detect H,K,L range from first and last rows */
  grid->H_min = Table_Index(sTable, 0, 0);
  grid->K_min = Table_Index(sTable, 0, 1);
  grid->L_min = Table_Index(sTable, 0, 2);
  grid->H_max = grid->H_min;
  grid->K_max = grid->K_min;
  grid->L_max = grid->L_min;
  
  /* Scan for actual min/max and fill grid */
  grid->E_max = 0;
  for (i = 0; i < total_rows; i++) {
    h_val = Table_Index(sTable, i, 0);
    k_val = Table_Index(sTable, i, 1);
    l_val = Table_Index(sTable, i, 2);
    e_val = Table_Index(sTable, i, 3);
    i_val = Table_Index(sTable, i, 4);
    b_val = (int)Table_Index(sTable, i, 5);
    
    if (h_val < grid->H_min) grid->H_min = h_val;
    if (h_val > grid->H_max) grid->H_max = h_val;
    if (k_val < grid->K_min) grid->K_min = k_val;
    if (k_val > grid->K_max) grid->K_max = k_val;
    if (l_val < grid->L_min) grid->L_min = l_val;
    if (l_val > grid->L_max) grid->L_max = l_val;
    if (fabs(e_val) > grid->E_max) grid->E_max = fabs(e_val);
  }
  
  grid->H_span = grid->H_max - grid->H_min;
  grid->K_span = grid->K_max - grid->K_min;
  grid->L_span = grid->L_max - grid->L_min;
  
  /* Compute grid spacing */
  grid->dH = (nx_detected > 1) ? grid->H_span / (nx_detected - 1) : 1.0;
  grid->dK = (ny_detected > 1) ? grid->K_span / (ny_detected - 1) : 1.0;
  grid->dL = (nz_detected > 1) ? grid->L_span / (nz_detected - 1) : 1.0;
  
  /* Fill the grid arrays.
     Assumed file ordering: rows are sorted by (H, K, L, branch) with
     branch varying fastest. Map each row to grid index. */
  for (i = 0; i < total_rows; i++) {
    h_val = Table_Index(sTable, i, 0);
    k_val = Table_Index(sTable, i, 1);
    l_val = Table_Index(sTable, i, 2);
    e_val = Table_Index(sTable, i, 3);
    i_val = Table_Index(sTable, i, 4);
    b_val = (int)Table_Index(sTable, i, 5);
    
    /* Map continuous r.l.u. to grid index */
    fH = (h_val - grid->H_min) / grid->dH;
    fK = (k_val - grid->K_min) / grid->dK;
    fL = (l_val - grid->L_min) / grid->dL;
    
    ix = (int)(fH + 0.5);  /* round to nearest */
    iy = (int)(fK + 0.5);
    iz = (int)(fL + 0.5);
    ib = b_val;
    
    /* Bounds check */
    if (ix < 0 || ix >= nx_detected || iy < 0 || iy >= ny_detected ||
        iz < 0 || iz >= nz_detected || ib < 0 || ib >= nb_detected) continue;
    
    flat_idx = ((ix * ny_detected + iy) * nz_detected + iz) * nb_detected + ib;
    grid->E_data[flat_idx] = e_val;
    grid->I_data[flat_idx] = i_val;
    if (has_gamma) {
      g_val = Table_Index(sTable, i, 6);
      grid->G_data[flat_idx] = g_val;
    }
  }
  
  grid->loaded = 1;
  
  Table_Free(&sTable);
  
  MPI_MASTER(
    printf("Phonon_DFT: Phonon grid range: H=[%g, %g] K=[%g, %g] L=[%g, %g]  E_max=%g meV\n",
           grid->H_min, grid->H_max, grid->K_min, grid->K_max,
           grid->L_min, grid->L_max, grid->E_max);
  );
  
  return 0;
}

/* ======================================================================
   Trilinear interpolation on the phonon grid for a single branch.
   
   q_rlu is in the file's coordinate system (already folded if tessellating).
   Returns energy and intensity by pointer. Returns 0 on success, -1 if 
   out of range.
   ====================================================================== */
int pdft_phonon_interp(pdft_phonon_grid *grid,
                       double qH, double qK, double qL, int branch,
                       double *E_out, double *I_out, double *G_out)
{
  double fH, fK, fL;
  int ix, iy, iz;
  double dx, dy, dz;
  int ix1, iy1, iz1;
  int nb, ny_loc, nz_loc;
  double e000, e001, e010, e011, e100, e101, e110, e111;
  double i000, i001, i010, i011, i100, i101, i110, i111;
  double e00, e01, e10, e11, e0, e1;
  double ii00, ii01, ii10, ii11, ii0, ii1;
  int idx;
  
  nb = grid->num_branches;
  ny_loc = grid->ny;
  nz_loc = grid->nz;
  
  /* Map to fractional grid index */
  fH = (qH - grid->H_min) / grid->dH;
  fK = (qK - grid->K_min) / grid->dK;
  fL = (qL - grid->L_min) / grid->dL;
  
  /* Integer part and fractional remainder */
  ix = (int)floor(fH);
  iy = (int)floor(fK);
  iz = (int)floor(fL);
  dx = fH - ix;
  dy = fK - iy;
  dz = fL - iz;
  
  /* Upper corner indices */
  ix1 = ix + 1;
  iy1 = iy + 1;
  iz1 = iz + 1;
  
  /* Clamp to grid bounds. When tessellating, values near the upper edge
     can land at ix = nx-1, needing ix1 = nx which is out of bounds.
     Wrap ix1 back to 0 (periodic boundary). For non-tessellating, return OOR. */
  if (ix < 0 || ix >= grid->nx ||
      iy < 0 || iy >= grid->ny ||
      iz < 0 || iz >= grid->nz) {
    *E_out = 0;
    *I_out = 0;
    if (G_out) *G_out = 0;
    return -1;
  }
  if (ix1 >= grid->nx) ix1 = 0;   /* periodic wrap */
  if (iy1 >= grid->ny) iy1 = 0;
  if (iz1 >= grid->nz) iz1 = 0;
  
  /* Fetch 8 corner values - energy */
  #define PDFT_GRID_IDX(gx,gy,gz,gb) (((gx)*ny_loc + (gy))*nz_loc + (gz))*nb + (gb)
  
  e000 = grid->E_data[PDFT_GRID_IDX(ix,  iy,  iz,  branch)];
  e001 = grid->E_data[PDFT_GRID_IDX(ix,  iy,  iz1, branch)];
  e010 = grid->E_data[PDFT_GRID_IDX(ix,  iy1, iz,  branch)];
  e011 = grid->E_data[PDFT_GRID_IDX(ix,  iy1, iz1, branch)];
  e100 = grid->E_data[PDFT_GRID_IDX(ix1, iy,  iz,  branch)];
  e101 = grid->E_data[PDFT_GRID_IDX(ix1, iy,  iz1, branch)];
  e110 = grid->E_data[PDFT_GRID_IDX(ix1, iy1, iz,  branch)];
  e111 = grid->E_data[PDFT_GRID_IDX(ix1, iy1, iz1, branch)];
  
  /* Trilinear interpolation for energy */
  e00 = e000 * (1-dx) + e100 * dx;
  e01 = e001 * (1-dx) + e101 * dx;
  e10 = e010 * (1-dx) + e110 * dx;
  e11 = e011 * (1-dx) + e111 * dx;
  e0  = e00  * (1-dy) + e10  * dy;
  e1  = e01  * (1-dy) + e11  * dy;
  *E_out = e0 * (1-dz) + e1 * dz;
  
  /* Same for intensity */
  i000 = grid->I_data[PDFT_GRID_IDX(ix,  iy,  iz,  branch)];
  i001 = grid->I_data[PDFT_GRID_IDX(ix,  iy,  iz1, branch)];
  i010 = grid->I_data[PDFT_GRID_IDX(ix,  iy1, iz,  branch)];
  i011 = grid->I_data[PDFT_GRID_IDX(ix,  iy1, iz1, branch)];
  i100 = grid->I_data[PDFT_GRID_IDX(ix1, iy,  iz,  branch)];
  i101 = grid->I_data[PDFT_GRID_IDX(ix1, iy,  iz1, branch)];
  i110 = grid->I_data[PDFT_GRID_IDX(ix1, iy1, iz,  branch)];
  i111 = grid->I_data[PDFT_GRID_IDX(ix1, iy1, iz1, branch)];
  
  ii00 = i000 * (1-dx) + i100 * dx;
  ii01 = i001 * (1-dx) + i101 * dx;
  ii10 = i010 * (1-dx) + i110 * dx;
  ii11 = i011 * (1-dx) + i111 * dx;
  ii0  = ii00 * (1-dy) + ii10 * dy;
  ii1  = ii01 * (1-dy) + ii11 * dy;
  *I_out = ii0 * (1-dz) + ii1 * dz;
  
  /* Gamma (linewidth) interpolation, if per-point data exists */
  if (G_out) {
    if (grid->G_data) {
      double g000, g001, g010, g011, g100, g101, g110, g111;
      double g00, g01, g10, g11, g0, g1;
      g000 = grid->G_data[PDFT_GRID_IDX(ix,  iy,  iz,  branch)];
      g001 = grid->G_data[PDFT_GRID_IDX(ix,  iy,  iz1, branch)];
      g010 = grid->G_data[PDFT_GRID_IDX(ix,  iy1, iz,  branch)];
      g011 = grid->G_data[PDFT_GRID_IDX(ix,  iy1, iz1, branch)];
      g100 = grid->G_data[PDFT_GRID_IDX(ix1, iy,  iz,  branch)];
      g101 = grid->G_data[PDFT_GRID_IDX(ix1, iy,  iz1, branch)];
      g110 = grid->G_data[PDFT_GRID_IDX(ix1, iy1, iz,  branch)];
      g111 = grid->G_data[PDFT_GRID_IDX(ix1, iy1, iz1, branch)];
      g00 = g000 * (1-dx) + g100 * dx;
      g01 = g001 * (1-dx) + g101 * dx;
      g10 = g010 * (1-dx) + g110 * dx;
      g11 = g011 * (1-dx) + g111 * dx;
      g0  = g00  * (1-dy) + g10  * dy;
      g1  = g01  * (1-dy) + g11  * dy;
      *G_out = g0 * (1-dz) + g1 * dz;
    } else {
      *G_out = 0;  /* caller will use global fallback */
    }
  }
  
  #undef PDFT_GRID_IDX
  
  return 0;
}

/* ======================================================================
   Fold Q (in r.l.u.) into the grid's range for tessellation.
   Modifies qH, qK, qL in place.
   ====================================================================== */
void pdft_fold_into_grid(pdft_phonon_grid *grid, double *qH, double *qK, double *qL)
{
  /* Shift so that grid minimum is at 0, then modulo by span, then shift back */
  if (grid->H_span > 1e-10) {
    *qH = *qH - grid->H_min;
    *qH = fmod(*qH, grid->H_span);
    if (*qH < 0) *qH += grid->H_span;
    *qH = *qH + grid->H_min;
  }
  if (grid->K_span > 1e-10) {
    *qK = *qK - grid->K_min;
    *qK = fmod(*qK, grid->K_span);
    if (*qK < 0) *qK += grid->K_span;
    *qK = *qK + grid->K_min;
  }
  if (grid->L_span > 1e-10) {
    *qL = *qL - grid->L_min;
    *qL = fmod(*qL, grid->L_span);
    if (*qL < 0) *qL += grid->L_span;
    *qL = *qL + grid->L_min;
  }
}

/* ======================================================================
   Phonon omega function for root-finding.
   
   Given a trial v_f and a fixed scattered direction (unit vector),
   compute Q = ki - kf, fold into the grid, interpolate E(q, branch),
   and return E_phonon - E_neutron.
   
   parms layout (all doubles, 13 elements):
     [0] = v_f (trial, modified by root finder)
     [1] = v_i
     [2..4] = vhat_fx, vhat_fy, vhat_fz (scattered direction, unit vector)
     [5..7] = vi_x, vi_y, vi_z (initial velocity vector)
     [8] = branch index (cast to int)
     [9] = sign (+1 for Stokes, -1 for anti-Stokes)
     [10] = tessellate flag
     [11] = grid pointer (encoded as double via memcpy)
     [12] = lattice pointer (encoded as double via memcpy)
   ====================================================================== */

double pdft_phonon_omega(double *parms)
{
  double v_f, v_i, vhat_fx, vhat_fy, vhat_fz, vi_x, vi_y, vi_z;
  int branch, sign_flag, tessellate;
  double qx, qy, qz;
  double qH, qK, qL;
  double E_phonon, I_phonon;
  double E_neutron;
  double Binv00, Binv01, Binv02, Binv10, Binv11, Binv12, Binv20, Binv21, Binv22;
  double det;
  int rc;
  pdft_phonon_grid *grid;
  pdft_lattice *lat;
  double a11, a12, a13, a21, a22, a23, a31, a32, a33;
  
  /* Extract grid and lattice pointers from parms via memcpy */
  memcpy(&grid, &parms[11], sizeof(pdft_phonon_grid *));
  memcpy(&lat,  &parms[12], sizeof(pdft_lattice *));
  
  if (!grid || !lat) return 1e30;
  
  v_f      = parms[0];
  v_i      = parms[1];
  vhat_fx  = parms[2];
  vhat_fy  = parms[3];
  vhat_fz  = parms[4];
  vi_x     = parms[5];
  vi_y     = parms[6];
  vi_z     = parms[7];
  branch   = (int)parms[8];
  sign_flag = (int)parms[9];
  tessellate = (int)parms[10];
  
  /* Compute Q = ki - kf in AA^-1 */
  qx = V2K * (vi_x - v_f * vhat_fx);
  qy = V2K * (vi_y - v_f * vhat_fy);
  qz = V2K * (vi_z - v_f * vhat_fz);
  
  /* Convert Q from AA^-1 to r.l.u.: invert B matrix */
  a11 = lat->asx; a12 = lat->bsx; a13 = lat->csx;
  a21 = lat->asy; a22 = lat->bsy; a23 = lat->csy;
  a31 = lat->asz; a32 = lat->bsz; a33 = lat->csz;
  
  det = a11*(a22*a33 - a23*a32) - a12*(a21*a33 - a23*a31) + a13*(a21*a32 - a22*a31);
  if (fabs(det) < 1e-30) return 1e30;
  
  Binv00 = (a22*a33 - a23*a32) / det;
  Binv01 = (a13*a32 - a12*a33) / det;
  Binv02 = (a12*a23 - a13*a22) / det;
  Binv10 = (a23*a31 - a21*a33) / det;
  Binv11 = (a11*a33 - a13*a31) / det;
  Binv12 = (a13*a21 - a11*a23) / det;
  Binv20 = (a21*a32 - a22*a31) / det;
  Binv21 = (a12*a31 - a11*a32) / det;
  Binv22 = (a11*a22 - a12*a21) / det;
  
  qH = Binv00 * qx + Binv01 * qy + Binv02 * qz;
  qK = Binv10 * qx + Binv11 * qy + Binv12 * qz;
  qL = Binv20 * qx + Binv21 * qy + Binv22 * qz;
  
  if (tessellate) {
    pdft_fold_into_grid(grid, &qH, &qK, &qL);
  }
  
  rc = pdft_phonon_interp(grid, qH, qK, qL, branch, &E_phonon, &I_phonon, NULL);
  if (rc != 0) return 1e30;
  
  /* Energy conservation: E_i - E_f = sign * E_phonon */
  E_neutron = VS2E * (v_i * v_i - v_f * v_f);
  
  return (sign_flag * E_phonon) - E_neutron;
}

/* ======================================================================
   Ridders' root-finding method for the phonon dispersion.
   Adapted from Phonon_simple's zridd, but calls pdft_phonon_omega.
   ====================================================================== */
#define PDFT_UNUSED (-1.11e30)
#define PDFT_MAXRIDD 60
#define PDFT_ROOTACC 1e-5

double pdft_zridd(double x1, double x2, double *parms, double xacc)
{
  int j;
  double ans, fh, fl, fm, fnew, s, xh, xl, xm, xnew;
  
  parms[0] = x1;
  fl = pdft_phonon_omega(parms);
  parms[0] = x2;
  fh = pdft_phonon_omega(parms);
  
  if (fl * fh >= 0) {
    if (fl == 0) return x1;
    if (fh == 0) return x2;
    return PDFT_UNUSED;
  }
  
  xl = x1; xh = x2;
  ans = PDFT_UNUSED;
  
  for (j = 0; j < PDFT_MAXRIDD; j++) {
    xm = 0.5 * (xl + xh);
    parms[0] = xm;
    fm = pdft_phonon_omega(parms);
    s = sqrt(fm * fm - fl * fh);
    if (s == 0.0) return ans;
    xnew = xm + (xm - xl) * ((fl >= fh ? 1.0 : -1.0) * fm / s);
    if (fabs(xnew - ans) <= xacc) return ans;
    ans = xnew;
    parms[0] = ans;
    fnew = pdft_phonon_omega(parms);
    if (fnew == 0.0) return ans;
    if (fm * fnew < 0) {
      xl = xm; fl = fm; xh = ans; fh = fnew;
    } else if (fl * fnew < 0) {
      xh = ans; fh = fnew;
    } else if (fh * fnew < 0) {
      xl = ans; fl = fnew;
    }
    if (fabs(xh - xl) <= xacc) return ans;
  }
  return ans;  /* max iterations reached */
}

#endif /* PHONON_DFT_DECL */
%}

DECLARE
%{
  pdft_info info;
  int pdft_phonon_attempts;
  int pdft_phonon_hits;
  int pdft_diag_printed;
%}

INITIALIZE
%{
  /* ALL declarations at top of block for MSVC C89 compatibility */
  int nrefl;
  Coords ToTarget;

  /* Initialize info struct */
  memset(&info, 0, sizeof(pdft_info));
  pdft_phonon_attempts = 0;
  pdft_phonon_hits = 0;
  pdft_diag_printed = 0;
  info.sigma_a = sigma_abs;
  info.sigma_i = sigma_inc;
  info.DW = debye_waller;
  info.flag_barns = barns;
  
  /* --- Geometry --- */
  if (xwidth > 0 && yheight > 0 && zdepth > 0)      info.shape = 1;  /* box */
  else if (radius > 0 && yheight > 0)                 info.shape = 0;  /* cylinder */
  else if (radius > 0 && yheight == 0)                 info.shape = 2;  /* sphere */
  else {
    fprintf(stderr, "Phonon_DFT: %s: ERROR: Invalid sample dimensions.\n"
            "  Specify radius+yheight (cylinder), xwidth+yheight+zdepth (box), "
            "or radius alone (sphere).\n", NAME_CURRENT_COMP);
    exit(-1);
  }
  
  /* --- Lattice --- */
  /* Compute lattice from user-specified parameters */
  if (a > 0 || ax || ay || az || bx || by || bz_l || cx || cy || cz) {
    pdft_compute_lattice(&info.lattice, a, b, c, alpha, beta, gamma_l,
                         ax, ay, az, bx, by, bz_l, cx, cy, cz);
    MPI_MASTER(
      printf("Phonon_DFT: %s: User lattice: V0=%g AA^3\n",
             NAME_CURRENT_COMP, info.lattice.V0);
    );
  }
  /* else: lattice may come from the reflection file header */
  
  /* --- Read Bragg reflections --- */
  if (reflections && strlen(reflections) && strcmp(reflections, "NULL")) {
    nrefl = pdft_read_bragg(reflections, &info);
    if (nrefl < 0) {
      fprintf(stderr, "Phonon_DFT: %s: ERROR reading reflections. Aborting.\n",
              NAME_CURRENT_COMP);
      exit(-1);
    }
    MPI_MASTER(
      printf("Phonon_DFT: %s: Loaded %d Bragg reflections from '%s'\n",
             NAME_CURRENT_COMP, info.bragg_count, reflections);
    );
  } else {
    MPI_MASTER(
      printf("Phonon_DFT: %s: No reflections file. No Bragg scattering.\n",
             NAME_CURRENT_COMP);
    );
  }
  
  /* --- Read phonon dispersion grid --- */
  info.phonon_grid.loaded = 0;
  if (dispersion && strlen(dispersion) && strcmp(dispersion, "NULL")) {
    if (pdft_read_phonon_grid(dispersion, &info.phonon_grid) < 0) {
      fprintf(stderr, "Phonon_DFT: %s: ERROR reading phonon dispersion. Aborting.\n",
              NAME_CURRENT_COMP);
      exit(-1);
    }
    if (info.phonon_grid.loaded) {
      MPI_MASTER(
        printf("Phonon_DFT: %s: Loaded phonon grid from '%s', tessellate=%d\n",
               NAME_CURRENT_COMP, dispersion, (int)tessellate);
        if (phonon_gamma > 0) {
          printf("Phonon_DFT: %s: Lorentzian spectral function mode: global Gamma=%g meV (FWHM)%s\n",
                 NAME_CURRENT_COMP, phonon_gamma,
                 info.phonon_grid.G_data ? ", per-point Gamma from file column 7" : "");
        } else {
          printf("Phonon_DFT: %s: Delta-function mode (root-finding, phonon_gamma=0)\n",
                 NAME_CURRENT_COMP);
        }
      );
    }
  } else {
    MPI_MASTER(
      printf("Phonon_DFT: %s: No dispersion file. No phonon scattering.\n",
             NAME_CURRENT_COMP);
    );
  }
  
  /* Validate lattice was set (either by user or file) */
  if (info.lattice.V0 <= 0) {
    fprintf(stderr, "Phonon_DFT: %s: ERROR: No lattice defined. "
            "Provide a, b, c or ax/ay/az etc., or a CIF file with lattice info.\n",
            NAME_CURRENT_COMP);
    exit(-1);
  }
  
  /* Validate cross sections */
  if (info.sigma_a < 0) info.sigma_a = 0;
  if (info.sigma_i < 0) info.sigma_i = 0;
  
  MPI_MASTER(
    printf("Phonon_DFT: %s: V0=%g [AA^3]  sigma_abs=%g [barn]  sigma_inc=%g [barn]\n",
           NAME_CURRENT_COMP, info.lattice.V0, info.sigma_a, info.sigma_i);
    printf("  Direct lattice:     a=[%g, %g, %g]  b=[%g, %g, %g]  c=[%g, %g, %g]\n",
           info.lattice.m_ax, info.lattice.m_ay, info.lattice.m_az,
           info.lattice.m_bx, info.lattice.m_by, info.lattice.m_bz,
           info.lattice.m_cx, info.lattice.m_cy, info.lattice.m_cz);
    printf("  Reciprocal lattice: a*=[%g, %g, %g]  b*=[%g, %g, %g]  c*=[%g, %g, %g]\n",
           info.lattice.asx, info.lattice.asy, info.lattice.asz,
           info.lattice.bsx, info.lattice.bsy, info.lattice.bsz,
           info.lattice.csx, info.lattice.csy, info.lattice.csz);
  );
  
  /* --- Focusing target --- */
  /* Note: target_index=0 with target_x/y/z=0 defaults to target_index=1
     (next component). This matches the McStas convention in Phonon_simple,
     Magnon_bcc, etc. To use explicit coordinates with no index-based
     targeting, set target_index=-1 or provide nonzero target_x/y/z. */
  if (target_index == 0 && target_x == 0 && target_y == 0 && target_z == 0)
    target_index = 1;
  if (target_index > 0) {
    ToTarget = coords_sub(POS_A_COMP_INDEX(INDEX_CURRENT_COMP + (int)target_index),
                          POS_A_CURRENT_COMP);
    ToTarget = rot_apply(ROT_A_CURRENT_COMP, ToTarget);
    coords_get(ToTarget, &target_x, &target_y, &target_z);
  }
  if (!(target_x || target_y || target_z)) {
    printf("Phonon_DFT: %s: No target defined. Using direct beam (Z-axis).\n",
           NAME_CURRENT_COMP);
    target_z = 1;
  }
  MPI_MASTER(
    printf("Phonon_DFT: %s: Focusing target at (%g, %g, %g) m\n",
           NAME_CURRENT_COMP, target_x, target_y, target_z);
  );
%}

TRACE
%{
  /* ALL declarations at top of TRACE for MSVC C89 compatibility */
  double t1, t2;
  int    intersect;
  double v_i, ki;
  double kix, kiy, kiz;
  double vx_i, vy_i, vz_i;
  double l_full, l_i, l_o;
  double dt0, dt;
  double V0;
  double abs_xlen, inc_xlen, coh_xlen, tot_xlen;
  double coh_refl, coh_xsect;
  int    tau_count;
  pdft_tau_data pdft_tlist[PDFT_MAX_TAU];
  double p_trans, mc_trans, mc_interact;
  double kfx, kfy, kfz;
  char   type;
  double l_scatter;
  double bragg_r, bragg_sum;
  int    bragg_j, bragg_idx;
  double kf_len, kf_adjust;
  double pmul;
  double cos_theta, sin_theta, phi_rand;
  double ph_parms[13];
  int    ph_branch, ph_sign, ph_nroots, ph_step, ph_sel, ph_i;
  pdft_phonon_root ph_roots[PDFT_MAX_PHONON_ROOTS];
  double ph_vf_max, ph_root_vf;
  double ph_E_phonon, ph_I_phonon, ph_omega, ph_bose;
  double ph_total_weight, ph_r_select, ph_weight_sum;
  double ph_step_lo, ph_step_hi;
  double solid_angle;
  double aim_x, aim_y, aim_z;
  double v_f;
  double ph_kappa2, ph_jacobian, ph_f1, ph_f2;
  double ph_p1, ph_p2, ph_p3, ph_p4;
  double ph_my_a_i, ph_my_a_f, ph_bose_factor;
  double scatt_channels;
  double p_incoming;
  /* Lorentzian spectral function mode variables */
  double lor_vf_min, lor_vf_max, lor_vf_range;
  double lor_qx, lor_qy, lor_qz, lor_qH, lor_qK, lor_qL;
  double lor_det, lor_Binv00, lor_Binv01, lor_Binv02;
  double lor_Binv10, lor_Binv11, lor_Binv12;
  double lor_Binv20, lor_Binv21, lor_Binv22;
  double lor_a11, lor_a12, lor_a13, lor_a21, lor_a22, lor_a23;
  double lor_a31, lor_a32, lor_a33;
  double lor_E_ph, lor_I_ph, lor_G_ph, lor_gamma_use;
  double lor_omega, lor_S_total, lor_lorentz, lor_denom;
  int    lor_b;
  /* Importance sampling of v_f: mixture of Lorentzians at predicted branch crossings */
  double imp_vf_targets[PDFT_MAX_BRANCHES * 2];  /* v_f targets for each (branch, sign) */
  double imp_vf_sigmas[PDFT_MAX_BRANCHES * 2];   /* HWHM in v_f space */
  int    imp_n_targets;
  double imp_est_qx, imp_est_qy, imp_est_qz;
  double imp_est_qH, imp_est_qK, imp_est_qL;
  double imp_E_est, imp_I_est, imp_G_est;
  double imp_vf_sq, imp_gamma_est, imp_sigma_vf;
  double imp_pdf, imp_comp_pdf, imp_uniform_weight;
  int    imp_sel, imp_j;
  double imp_u, imp_t_sample;

  intersect = 0;
  type = 't';

  if (info.shape == 0)
    intersect = cylinder_intersect(&t1, &t2, x, y, z, vx, vy, vz, radius, yheight);
  else if (info.shape == 1)
    intersect = box_intersect(&t1, &t2, x, y, z, vx, vy, vz, xwidth, yheight, zdepth);
  else if (info.shape == 2)
    intersect = sphere_intersect(&t1, &t2, x, y, z, vx, vy, vz, radius);

  if (!intersect || t2 <= 0) {
    /* Missed or already past */
  }
  else if (t1 < 0) {
    ABSORB;
  }
  else {
    /* Neutron enters at t=t1 */
    dt0 = t2 - t1;
    v_i = sqrt(vx*vx + vy*vy + vz*vz);
    l_full = v_i * dt0;
    dt = rand01() * dt0;
    l_i = v_i * dt;
    vx_i = vx; vy_i = vy; vz_i = vz;
    PROP_DT(dt + t1);
    V0 = info.lattice.V0;
    p_incoming = p;

    /* === CHANNEL DECISION: simple coin flip === */

    if (info.phonon_grid.loaded && p_phonon > 0 && rand01() < p_phonon) {
      /* ============================================================
         PHONON PATH: follows Phonon_simple algorithm exactly.
         Weight is computed from scratch using p_incoming.
         ============================================================ */

      aim_x = target_x - x;
      aim_y = target_y - y;
      aim_z = target_z - z;

      if (focus_aw > 0 && focus_ah > 0) {
        randvec_target_rect_angular(&vx, &vy, &vz, &solid_angle,
          aim_x, aim_y, aim_z, focus_aw, focus_ah, ROT_A_CURRENT_COMP);
      } else if (focus_xw > 0 && focus_yh > 0) {
        randvec_target_rect(&vx, &vy, &vz, &solid_angle,
          aim_x, aim_y, aim_z, focus_xw, focus_yh, ROT_A_CURRENT_COMP);
      } else if (focus_r > 0) {
        randvec_target_sphere(&vx, &vy, &vz, &solid_angle,
          aim_x, aim_y, aim_z, focus_r);
      } else {
        cos_theta = 2*rand01() - 1;
        sin_theta = sqrt(1 - cos_theta*cos_theta);
        phi_rand = 2*PI*rand01();
        vx = sin_theta * cos(phi_rand);
        vy = sin_theta * sin(phi_rand);
        vz = cos_theta;
        solid_angle = 4*PI;
      }
      NORM(vx, vy, vz);

      if (phonon_gamma > 0) {
        /* ============================================================
           LORENTZIAN SPECTRAL FUNCTION MODE (Phase 2)
           
           Instead of root-finding, choose a random v_f, compute the
           energy transfer omega, then evaluate S(Q,omega) as a sum
           of Lorentzians over all branches.  Every neutron contributes
           (no root-finding failures), weighted by the spectral function.
           
           S(Q,omega) = sum_s I_s(q) * (gamma_s/pi) / ((omega - omega_s)^2 + gamma_s^2)
                        * [n(omega,T) + 1]
           where gamma_s = FWHM/2 (HWHM) is used internally for the Lorentzian,
           but the user-facing parameter phonon_gamma and file column 7 are FWHM.
           
           Weight = p_incoming * p1 * p2_lor * p3_lor / p_phonon
           where:
             p1     = absorption along path
             p2_lor = solid_angle * l_full * V_rho / (4*PI)
             p3_lor = (vf/vi) * DW * kappa2 * K2V^2 * vf_range * S(Q,omega)
           
           The vf_range factor accounts for the uniform sampling density
           of v_f over [vf_min, vf_max].
           ============================================================ */

        /* v_f sampling range: from nearly zero to v_i + SE2V*sqrt(E_max)
           (covers both Stokes and anti-Stokes) */
        lor_vf_min = 1e-3;
        lor_vf_max = v_i + SE2V * sqrt(info.phonon_grid.E_max);
        lor_vf_range = lor_vf_max - lor_vf_min;

        /* ============================================================
           IMPORTANCE-SAMPLED v_f
           
           Estimate where each phonon branch crosses the energy
           conservation surface for this scattered direction, then
           sample v_f from a mixture of Lorentzians centered at
           those crossings plus a uniform background.
           
           1. Compute Q at v_f = v_i (elastic approximation)
           2. For each (branch, sign), get E_s(q) and compute
              v_f_target = sqrt(v_i^2 -/+ E_s/VS2E)
           3. Convert phonon linewidth Gamma to v_f space:
              sigma_vf = Gamma / (2 * VS2E * v_f_target)
           4. Sample from mixture: (1-w_uni)*Lorentzian_mix + w_uni*Uniform
           5. Divide weight by pdf(v_f) from this mixture
           ============================================================ */

        /* Compute B^-1 (needed for Q->rlu, shared by estimation and evaluation) */
        lor_a11 = info.lattice.asx; lor_a12 = info.lattice.bsx; lor_a13 = info.lattice.csx;
        lor_a21 = info.lattice.asy; lor_a22 = info.lattice.bsy; lor_a23 = info.lattice.csy;
        lor_a31 = info.lattice.asz; lor_a32 = info.lattice.bsz; lor_a33 = info.lattice.csz;

        lor_det = lor_a11*(lor_a22*lor_a33 - lor_a23*lor_a32)
                - lor_a12*(lor_a21*lor_a33 - lor_a23*lor_a31)
                + lor_a13*(lor_a21*lor_a32 - lor_a22*lor_a31);

        if (fabs(lor_det) < 1e-30) {
          /* Degenerate lattice, skip */
          vx = vx_i; vy = vy_i; vz = vz_i;
        } else {
          lor_Binv00 = (lor_a22*lor_a33 - lor_a23*lor_a32) / lor_det;
          lor_Binv01 = (lor_a13*lor_a32 - lor_a12*lor_a33) / lor_det;
          lor_Binv02 = (lor_a12*lor_a23 - lor_a13*lor_a22) / lor_det;
          lor_Binv10 = (lor_a23*lor_a31 - lor_a21*lor_a33) / lor_det;
          lor_Binv11 = (lor_a11*lor_a33 - lor_a13*lor_a31) / lor_det;
          lor_Binv12 = (lor_a13*lor_a21 - lor_a11*lor_a23) / lor_det;
          lor_Binv20 = (lor_a21*lor_a32 - lor_a22*lor_a31) / lor_det;
          lor_Binv21 = (lor_a12*lor_a31 - lor_a11*lor_a32) / lor_det;
          lor_Binv22 = (lor_a11*lor_a22 - lor_a12*lor_a21) / lor_det;

          /* Step 1: Estimate Q at elastic limit (v_f = v_i) in r.l.u. */
          imp_est_qx = V2K * (vx_i - v_i * vx);
          imp_est_qy = V2K * (vy_i - v_i * vy);
          imp_est_qz = V2K * (vz_i - v_i * vz);
          imp_est_qH = lor_Binv00*imp_est_qx + lor_Binv01*imp_est_qy + lor_Binv02*imp_est_qz;
          imp_est_qK = lor_Binv10*imp_est_qx + lor_Binv11*imp_est_qy + lor_Binv12*imp_est_qz;
          imp_est_qL = lor_Binv20*imp_est_qx + lor_Binv21*imp_est_qy + lor_Binv22*imp_est_qz;
          if (tessellate) pdft_fold_into_grid(&info.phonon_grid, &imp_est_qH, &imp_est_qK, &imp_est_qL);

          /* Step 2: Build importance-sampling targets for each (branch, sign) */
          imp_n_targets = 0;
          for (lor_b = 0; lor_b < info.phonon_grid.num_branches; lor_b++) {
            if (pdft_phonon_interp(&info.phonon_grid, imp_est_qH, imp_est_qK, imp_est_qL, lor_b,
                                   &imp_E_est, &imp_I_est, &imp_G_est) != 0)
              continue;
            if (fabs(imp_E_est) < 1e-10) continue;  /* skip acoustic at zone center */

            /* Linewidth in energy: per-point or global, FWHM -> HWHM */
            imp_gamma_est = (imp_G_est > 0) ? imp_G_est : phonon_gamma;
            if (imp_gamma_est <= 0) imp_gamma_est = phonon_gamma;
            imp_gamma_est *= 0.5;  /* FWHM -> HWHM */

            /* Stokes: v_f^2 = v_i^2 - E_s/VS2E */
            imp_vf_sq = v_i * v_i - imp_E_est / VS2E;
            if (imp_vf_sq > 1e-6 && imp_n_targets < PDFT_MAX_BRANCHES * 2) {
              imp_vf_targets[imp_n_targets] = sqrt(imp_vf_sq);
              /* Transform HWHM from energy to v_f space: dE/dvf = 2*VS2E*vf */
              imp_sigma_vf = imp_gamma_est / (2.0 * VS2E * imp_vf_targets[imp_n_targets]);
              if (imp_sigma_vf < 10.0) imp_sigma_vf = 10.0;  /* floor: ~10 m/s min width */
              imp_vf_sigmas[imp_n_targets] = imp_sigma_vf;
              imp_n_targets++;
            }

            /* Anti-Stokes: v_f^2 = v_i^2 + E_s/VS2E */
            imp_vf_sq = v_i * v_i + imp_E_est / VS2E;
            if (imp_vf_sq > 1e-6 && imp_n_targets < PDFT_MAX_BRANCHES * 2) {
              imp_vf_targets[imp_n_targets] = sqrt(imp_vf_sq);
              imp_sigma_vf = imp_gamma_est / (2.0 * VS2E * imp_vf_targets[imp_n_targets]);
              if (imp_sigma_vf < 10.0) imp_sigma_vf = 10.0;
              imp_vf_sigmas[imp_n_targets] = imp_sigma_vf;
              imp_n_targets++;
            }
          }

          /* Step 3: Sample v_f from mixture.
             PDF = (1-w_uni) * (1/N) * sum_j Lor(v_f; center_j, sigma_j) + w_uni / vf_range
             where w_uni = 0.1 ensures coverage even far from branches.
             If no targets found, fall back to pure uniform. */
          imp_uniform_weight = 0.1;
          if (imp_n_targets == 0) imp_uniform_weight = 1.0;

          if (rand01() < imp_uniform_weight || imp_n_targets == 0) {
            /* Uniform component */
            v_f = lor_vf_min + rand01() * lor_vf_range;
          } else {
            /* Pick a random target, sample from its Cauchy (Lorentzian in v_f) */
            imp_sel = (int)(rand01() * imp_n_targets);
            if (imp_sel >= imp_n_targets) imp_sel = imp_n_targets - 1;
            /* Cauchy sampling: v_f = center + sigma * tan(pi*(u - 0.5)) */
            imp_u = rand01();
            /* Clamp u away from 0 and 1 to avoid tan divergence */
            if (imp_u < 1e-8) imp_u = 1e-8;
            if (imp_u > 1.0 - 1e-8) imp_u = 1.0 - 1e-8;
            imp_t_sample = imp_vf_targets[imp_sel]
                         + imp_vf_sigmas[imp_sel] * tan(PI * (imp_u - 0.5));
            /* Reject if outside valid range, fall back to uniform */
            if (imp_t_sample < lor_vf_min || imp_t_sample > lor_vf_max) {
              v_f = lor_vf_min + rand01() * lor_vf_range;
            } else {
              v_f = imp_t_sample;
            }
          }

          /* Step 4: Compute the mixture PDF at the sampled v_f */
          imp_pdf = imp_uniform_weight / lor_vf_range;
          if (imp_n_targets > 0) {
            imp_comp_pdf = 0;
            for (imp_j = 0; imp_j < imp_n_targets; imp_j++) {
              lor_denom = (v_f - imp_vf_targets[imp_j]) * (v_f - imp_vf_targets[imp_j])
                        + imp_vf_sigmas[imp_j] * imp_vf_sigmas[imp_j];
              imp_comp_pdf += (imp_vf_sigmas[imp_j] / PI) / lor_denom;
            }
            imp_comp_pdf /= imp_n_targets;  /* equal-weight mixture */
            imp_pdf += (1.0 - imp_uniform_weight) * imp_comp_pdf;
          }
          /* Safety floor for pdf to avoid division by zero */
          if (imp_pdf < 1e-30) imp_pdf = 1e-30;

          /* Set final velocity */
          vx *= v_f;
          vy *= v_f;
          vz *= v_f;

          /* Energy transfer: omega = E_i - E_f (positive = neutron loses energy) */
          lor_omega = VS2E * (v_i * v_i - v_f * v_f);

          /* Compute Q = ki - kf in AA^-1 */
          lor_qx = V2K * (vx_i - vx);
          lor_qy = V2K * (vy_i - vy);
          lor_qz = V2K * (vz_i - vz);

          ph_kappa2 = lor_qx*lor_qx + lor_qy*lor_qy + lor_qz*lor_qz;

          /* Convert Q to r.l.u. (reuse B^-1 computed above) */
          lor_qH = lor_Binv00*lor_qx + lor_Binv01*lor_qy + lor_Binv02*lor_qz;
          lor_qK = lor_Binv10*lor_qx + lor_Binv11*lor_qy + lor_Binv12*lor_qz;
          lor_qL = lor_Binv20*lor_qx + lor_Binv21*lor_qy + lor_Binv22*lor_qz;

          if (tessellate) pdft_fold_into_grid(&info.phonon_grid, &lor_qH, &lor_qK, &lor_qL);

          /* Sum Lorentzian spectral function over all branches */
          lor_S_total = 0;
          for (lor_b = 0; lor_b < info.phonon_grid.num_branches; lor_b++) {
            if (pdft_phonon_interp(&info.phonon_grid, lor_qH, lor_qK, lor_qL, lor_b,
                                   &lor_E_ph, &lor_I_ph, &lor_G_ph) != 0)
              continue;
            if (lor_I_ph <= 0) continue;
            if (fabs(lor_E_ph) < 1e-10) continue;  /* skip acoustic at zone center */

            /* Determine linewidth: per-point from file, or global fallback.
               Both phonon_gamma and G_data store FWHM; convert to HWHM for the Lorentzian. */
            lor_gamma_use = (lor_G_ph > 0) ? lor_G_ph : phonon_gamma;
            if (lor_gamma_use <= 0) lor_gamma_use = phonon_gamma;  /* safety */
            lor_gamma_use *= 0.5;  /* FWHM -> HWHM */

            /* Lorentzian: L(omega, omega_s, Gamma) = (Gamma/pi) / ((omega - omega_s)^2 + Gamma^2)
               Evaluate for both +omega_s (Stokes) and -omega_s (anti-Stokes) */
            /* Stokes: neutron loses energy, creates phonon */
            lor_denom = (lor_omega - lor_E_ph)*(lor_omega - lor_E_ph) + lor_gamma_use*lor_gamma_use;
            lor_lorentz = (lor_gamma_use / PI) / lor_denom;
            lor_S_total += lor_I_ph * lor_lorentz * pdft_nbose(lor_omega, T);

            /* Anti-Stokes: neutron gains energy, absorbs phonon */
            lor_denom = (lor_omega + lor_E_ph)*(lor_omega + lor_E_ph) + lor_gamma_use*lor_gamma_use;
            lor_lorentz = (lor_gamma_use / PI) / lor_denom;
            lor_S_total += lor_I_ph * lor_lorentz * pdft_nbose(-lor_omega, T);
          }

          /* Outgoing path length */
          if (info.shape == 0)
            intersect = cylinder_intersect(&t1, &t2, x, y, z, vx, vy, vz, radius, yheight);
          else if (info.shape == 1)
            intersect = box_intersect(&t1, &t2, x, y, z, vx, vy, vz, xwidth, yheight, zdepth);
          else if (info.shape == 2)
            intersect = sphere_intersect(&t1, &t2, x, y, z, vx, vy, vz, radius);
          l_o = (intersect && t2 > 0) ? v_f * t2 : 0;

          /* Weight factors for Lorentzian mode with importance-sampled v_f:
             p1 = exp(-mu_a,i * l_i - mu_a,f * l_o)  (absorption)
             p2 = solid_angle * l_full * V_rho / (4*PI)  (geometry)
             p3 = (vf/vi) * DW * kappa2 * K2V^2 * S_total / pdf_mixture(v_f)
             
             The importance sampling replaces the uniform-sampling Jacobian
             (vf_range) with 1/pdf_mixture(v_f).  When v_f lands near a
             phonon branch, both S_total and pdf are large; their ratio
             is well-behaved and the weight variance is much smaller than
             with uniform sampling where S_total alone can vary by orders
             of magnitude. */
          ph_my_a_i = info.sigma_a * 2200 / v_i * (4.0 / V0) * 100;
          ph_my_a_f = info.sigma_a * 2200 / v_f * (4.0 / V0) * 100;
          ph_p1 = exp(-(ph_my_a_i * l_i + ph_my_a_f * l_o));
          ph_p2 = solid_angle * l_full * (4.0 / V0) / (4*PI);
          ph_p3 = (v_f / v_i) * info.DW * (ph_kappa2 * K2V * K2V)
                  * lor_S_total / imp_pdf;

          p = p_incoming * ph_p1 * ph_p2 * ph_p3 / p_phonon;

          pdft_phonon_attempts++;
          pdft_phonon_hits++;  /* every neutron contributes in Lorentzian mode */

          if (pdft_phonon_attempts <= 5) {
            printf("Phonon_DFT: LORENTZIAN p=%g (p_in=%g, p1=%g, p2=%g, p3=%g)\n",
                   p, p_incoming, ph_p1, ph_p2, ph_p3);
            printf("  omega=%g vf=%g vi=%g S_total=%g kappa2=%g pdf=%g n_tgt=%d\n",
                   lor_omega, v_f, v_i, lor_S_total, ph_kappa2, imp_pdf, imp_n_targets);
          }

          type = 'p';
          SCATTER;
        }
      }
      else {
      /* ============================================================
         ROOT-FINDING MODE (original Phonon_simple algorithm)
         phonon_gamma == 0: delta-function phonons
         ============================================================ */
      ph_parms[1] = v_i;
      ph_parms[2] = vx; ph_parms[3] = vy; ph_parms[4] = vz;
      ph_parms[5] = vx_i; ph_parms[6] = vy_i; ph_parms[7] = vz_i;
      ph_parms[10] = (double)tessellate;
      {
        pdft_phonon_grid *pg;
        pdft_lattice *pl;
        pg = &info.phonon_grid;
        pl = &info.lattice;
        memcpy(&ph_parms[11], &pg, sizeof(pdft_phonon_grid *));
        memcpy(&ph_parms[12], &pl, sizeof(pdft_lattice *));
      }

      ph_vf_max = v_i + SE2V * sqrt(info.phonon_grid.E_max);

      ph_nroots = 0;
      for (ph_branch = 0; ph_branch < info.phonon_grid.num_branches && ph_nroots < PDFT_MAX_PHONON_ROOTS; ph_branch++) {
        for (ph_sign = -1; ph_sign <= 1; ph_sign += 2) {
          ph_parms[8] = (double)ph_branch;
          ph_parms[9] = (double)ph_sign;
          for (ph_step = 0; ph_step < phonon_e_steps && ph_nroots < PDFT_MAX_PHONON_ROOTS; ph_step++) {
            if (ph_sign > 0) {
              ph_step_lo = v_i * ph_step / phonon_e_steps;
              ph_step_hi = v_i * (ph_step + 1) / phonon_e_steps;
            } else {
              ph_step_lo = v_i + (ph_vf_max - v_i) * ph_step / phonon_e_steps;
              ph_step_hi = v_i + (ph_vf_max - v_i) * (ph_step + 1) / phonon_e_steps;
            }
            if (ph_step_lo < 1e-3) ph_step_lo = 1e-3;
            ph_root_vf = pdft_zridd(ph_step_lo, ph_step_hi, ph_parms, PDFT_ROOTACC);
            if (ph_root_vf != PDFT_UNUSED && ph_root_vf > 1e-3) {
              double tmp_qH, tmp_qK, tmp_qL;
              double root_E_ph, root_I_ph;
              /* Evaluate intensity at the root q-point */
              {
                double root_qx, root_qy, root_qz;
                double det_B, Binv00, Binv01, Binv02, Binv10, Binv11, Binv12, Binv20, Binv21, Binv22;
                double a11l, a12l, a13l, a21l, a22l, a23l, a31l, a32l, a33l;
                pdft_lattice *latptr = &info.lattice;
                root_qx = V2K * (vx_i - ph_root_vf * vx);
                root_qy = V2K * (vy_i - ph_root_vf * vy);
                root_qz = V2K * (vz_i - ph_root_vf * vz);
                a11l = latptr->asx; a12l = latptr->bsx; a13l = latptr->csx;
                a21l = latptr->asy; a22l = latptr->bsy; a23l = latptr->csy;
                a31l = latptr->asz; a32l = latptr->bsz; a33l = latptr->csz;
                det_B = a11l*(a22l*a33l - a23l*a32l) - a12l*(a21l*a33l - a23l*a31l) + a13l*(a21l*a32l - a22l*a31l);
                if (fabs(det_B) > 1e-30) {
                  Binv00 = (a22l*a33l - a23l*a32l) / det_B;
                  Binv01 = (a13l*a32l - a12l*a33l) / det_B;
                  Binv02 = (a12l*a23l - a13l*a22l) / det_B;
                  Binv10 = (a23l*a31l - a21l*a33l) / det_B;
                  Binv11 = (a11l*a33l - a13l*a31l) / det_B;
                  Binv12 = (a13l*a21l - a11l*a23l) / det_B;
                  Binv20 = (a21l*a32l - a22l*a31l) / det_B;
                  Binv21 = (a12l*a31l - a11l*a32l) / det_B;
                  Binv22 = (a11l*a22l - a12l*a21l) / det_B;
                  tmp_qH = Binv00*root_qx + Binv01*root_qy + Binv02*root_qz;
                  tmp_qK = Binv10*root_qx + Binv11*root_qy + Binv12*root_qz;
                  tmp_qL = Binv20*root_qx + Binv21*root_qy + Binv22*root_qz;
                  if (tessellate) pdft_fold_into_grid(&info.phonon_grid, &tmp_qH, &tmp_qK, &tmp_qL);
                  if (pdft_phonon_interp(&info.phonon_grid, tmp_qH, tmp_qK, tmp_qL, ph_branch, &root_E_ph, &root_I_ph, NULL) != 0)
                    root_I_ph = 1.0;
                } else {
                  root_I_ph = 1.0;
                }
              }
              ph_roots[ph_nroots].v_f = ph_root_vf;
              ph_roots[ph_nroots].omega = VS2E * (v_i * v_i - ph_root_vf * ph_root_vf);
              ph_roots[ph_nroots].branch = ph_branch;
              ph_roots[ph_nroots].intensity = root_I_ph;
              ph_nroots++;
            }
          }
        }
      }

      pdft_phonon_attempts++;
      if (ph_nroots > 0) pdft_phonon_hits++;

      if (ph_nroots == 0) {
        /* No phonon roots found: restore original velocity so neutron
           is not left with a unit-vector speed of 1 m/s.
           Fall through to transmission (type='t' remains set). */
        vx = vx_i; vy = vy_i; vz = vz_i;
      }

      if (ph_nroots > 0) {
        /* Select one root randomly (uniform, like Phonon_simple) */
        ph_sel = (int)floor(rand01() * ph_nroots);
        if (ph_sel >= ph_nroots) ph_sel = ph_nroots - 1;
        v_f = ph_roots[ph_sel].v_f;
        ph_omega = ph_roots[ph_sel].omega;

        /* Jacobian */
        ph_parms[8] = (double)ph_roots[ph_sel].branch;
        ph_parms[9] = (ph_omega > 0) ? 1.0 : -1.0;
        ph_parms[0] = v_f - 1.0;
        ph_f1 = pdft_phonon_omega(ph_parms);
        ph_parms[0] = v_f + 1.0;
        ph_f2 = pdft_phonon_omega(ph_parms);
        ph_jacobian = fabs(ph_f2 - ph_f1) / 2.0;
        if (ph_jacobian < 1e-10) ph_jacobian = 1e-10;

        /* Set final velocity */
        vx *= v_f;
        vy *= v_f;
        vz *= v_f;

        ph_kappa2 = V2K*V2K * ((vx_i-vx)*(vx_i-vx) + (vy_i-vy)*(vy_i-vy) + (vz_i-vz)*(vz_i-vz));

        /* Outgoing path length */
        if (info.shape == 0)
          intersect = cylinder_intersect(&t1, &t2, x, y, z, vx, vy, vz, radius, yheight);
        else if (info.shape == 1)
          intersect = box_intersect(&t1, &t2, x, y, z, vx, vy, vz, xwidth, yheight, zdepth);
        else if (info.shape == 2)
          intersect = sphere_intersect(&t1, &t2, x, y, z, vx, vy, vz, radius);
        l_o = (intersect && t2 > 0) ? v_f * t2 : 0;

        ph_bose_factor = pdft_nbose(ph_omega, T);

        /* Weight: follows Phonon_simple formula, with grid intensity included.
           p1 = absorption
           p2 = nf * solid_angle * l_full * V_rho / (4*PI)
           p3 = (vf/vi) * DW * kappa2*K2V^2*VS2E / |omega| * bose * intensity
           p4 = 2*VS2E*vf / J_factor 
           We use V_rho = 4/V0 for the 4 atoms per fcc cell.
           The grid intensity (ph_roots[].intensity) plays the role of b^2/M
           from Phonon_simple; it encodes the DFT-calculated structure factor. */
        ph_my_a_i = info.sigma_a * 2200 / v_i * (4.0 / V0) * 100;
        ph_my_a_f = info.sigma_a * 2200 / v_f * (4.0 / V0) * 100;
        ph_p1 = exp(-(ph_my_a_i * l_i + ph_my_a_f * l_o));
        ph_p2 = ph_nroots * solid_angle * l_full * (4.0 / V0) / (4*PI);
        ph_p3 = (fabs(ph_omega) > 1e-10) 
          ? (v_f / v_i) * info.DW * (ph_kappa2 * K2V * K2V * VS2E) / fabs(ph_omega) * ph_bose_factor
            * ph_roots[ph_sel].intensity
          : 0;
        ph_p4 = 2 * VS2E * v_f / ph_jacobian;

        p = p_incoming * ph_p1 * ph_p2 * ph_p3 * ph_p4 / p_phonon;

        if (pdft_phonon_attempts <= 5) {
          printf("Phonon_DFT: PHONON p=%g (p_in=%g, p1=%g, p2=%g, p3=%g, p4=%g)\n",
                 p, p_incoming, ph_p1, ph_p2, ph_p3, ph_p4);
          printf("  omega=%g vf=%g vi=%g nroots=%d kappa2=%g bose=%g solid=%g l_full=%g\n",
                 ph_omega, v_f, v_i, ph_nroots, ph_kappa2, ph_bose_factor, solid_angle, l_full);
        }

        type = 'p';
        SCATTER;
      }
      /* else: no roots, neutron transmitted unchanged (velocity already restored above) */
      } /* end root-finding (else) block */
    }
    else if (info.bragg_count > 0 || info.sigma_i > 0) {
      /* ============================================================
         BRAGG + INCOHERENT PATH (unchanged from working version)
         ============================================================ */
      kix = V2K * vx_i;
      kiy = V2K * vy_i;
      kiz = V2K * vz_i;
      ki = V2K * v_i;

      abs_xlen = info.sigma_a * 2200 / v_i / V0 * 100;
      inc_xlen = info.sigma_i / V0 * 100;

      tau_count = 0; coh_refl = 0; coh_xsect = 0;
      if (info.bragg_count > 0) {
        tau_count = pdft_bragg_search(info.bragg_list, pdft_tlist,
                                      info.bragg_count, V0,
                                      kix, kiy, kiz,
                                      delta_d_d,
                                      &coh_refl, &coh_xsect);
      }
      coh_xlen = coh_xsect / V0;
      if (info.flag_barns) coh_xlen *= 100;

      tot_xlen = abs_xlen + inc_xlen + coh_xlen;

      if (tot_xlen > 0) {
        p_trans = exp(-tot_xlen * l_full);
        mc_trans = 1.0 - p_interact;
        if (mc_trans < 0) mc_trans = 0;
        if (mc_trans > 1) mc_trans = 1;
        mc_interact = 1.0 - mc_trans;

        if (mc_trans >= 1 || (mc_trans > 0 && rand01() < mc_trans)) {
          p *= p_trans / mc_trans;
          type = 't';
        }
        else {
          p *= fabs(1.0 - p_trans) / mc_interact;

          if (tot_xlen * l_full < 1e-6)
            l_scatter = rand0max(l_full);
          else
            l_scatter = -log(1 - rand0max(1 - exp(-tot_xlen * l_full))) / tot_xlen;

          scatt_channels = coh_xlen + inc_xlen;
          if (scatt_channels > 0) {
            p *= scatt_channels / tot_xlen;
          } else {
            ABSORB;
          }

          /* Compensate for (1-p_phonon) probability */
          if (p_phonon > 0 && p_phonon < 1.0) p /= (1.0 - p_phonon);

          if (coh_xlen > 0 && rand0max(scatt_channels) > inc_xlen) {
            /* BRAGG */
            bragg_r = rand0max(coh_refl);
            bragg_sum = 0;
            for (bragg_j = 0; bragg_j < tau_count; bragg_j++) {
              bragg_sum += pdft_tlist[bragg_j].refl;
              if (bragg_sum > bragg_r) break;
            }
            if (bragg_j >= tau_count) bragg_j = tau_count - 1;
            bragg_idx = pdft_tlist[bragg_j].index;
            kfx = kix - info.bragg_list[bragg_idx].tau_x;
            kfy = kiy - info.bragg_list[bragg_idx].tau_y;
            kfz = kiz - info.bragg_list[bragg_idx].tau_z;
            kf_len = sqrt(kfx*kfx + kfy*kfy + kfz*kfz);
            if (kf_len > 0) {
              kf_adjust = ki / kf_len;
              kfx *= kf_adjust; kfy *= kf_adjust; kfz *= kf_adjust;
            }
            vx = kfx * K2V; vy = kfy * K2V; vz = kfz * K2V;
            if (coh_xsect > 0 && pdft_tlist[bragg_j].refl > 0) {
              pmul = pdft_tlist[bragg_j].xsect * coh_refl
                     / (coh_xsect * pdft_tlist[bragg_j].refl);
              if (!isnan(pmul) && pmul > 0) p *= pmul;
            }
            p *= info.DW;
            type = 'c';
            SCATTER;
          }
          else {
            /* INCOHERENT */
            cos_theta = 2*rand01() - 1;
            sin_theta = sqrt(1 - cos_theta*cos_theta);
            phi_rand = 2*PI*rand01();
            vx = v_i * sin_theta * cos(phi_rand);
            vy = v_i * sin_theta * sin(phi_rand);
            vz = v_i * cos_theta;
            type = 'i';
            SCATTER;
          }
        }
      }
    }
  }
%}

FINALLY
%{
  if (info.bragg_list) free(info.bragg_list);
  if (info.phonon_grid.E_data) free(info.phonon_grid.E_data);
  if (info.phonon_grid.I_data) free(info.phonon_grid.I_data);
  if (info.phonon_grid.G_data) free(info.phonon_grid.G_data);
  printf("Phonon_DFT: %s: SUMMARY: %d phonon attempts, %d found roots (%g%%)\n",
         NAME_CURRENT_COMP, pdft_phonon_attempts, pdft_phonon_hits,
         pdft_phonon_attempts > 0 ? 100.0*pdft_phonon_hits/pdft_phonon_attempts : 0.0);
%}

MCDISPLAY
%{
  if (info.shape == 0) {  /* cylinder */
    circle("xz", 0,  yheight/2.0, 0, radius);
    circle("xz", 0, -yheight/2.0, 0, radius);
    line(-radius, -yheight/2.0, 0, -radius, +yheight/2.0, 0);
    line(+radius, -yheight/2.0, 0, +radius, +yheight/2.0, 0);
    line(0, -yheight/2.0, -radius, 0, +yheight/2.0, -radius);
    line(0, -yheight/2.0, +radius, 0, +yheight/2.0, +radius);
  }
  else if (info.shape == 1) {  /* box */
    double xmin = -0.5*xwidth;
    double xmax =  0.5*xwidth;
    double ymin = -0.5*yheight;
    double ymax =  0.5*yheight;
    double zmin = -0.5*zdepth;
    double zmax =  0.5*zdepth;
    multiline(5, xmin, ymin, zmin, xmax, ymin, zmin,
                 xmax, ymax, zmin, xmin, ymax, zmin, xmin, ymin, zmin);
    multiline(5, xmin, ymin, zmax, xmax, ymin, zmax,
                 xmax, ymax, zmax, xmin, ymax, zmax, xmin, ymin, zmax);
    line(xmin, ymin, zmin, xmin, ymin, zmax);
    line(xmax, ymin, zmin, xmax, ymin, zmax);
    line(xmin, ymax, zmin, xmin, ymax, zmax);
    line(xmax, ymax, zmin, xmax, ymax, zmax);
  }
  else if (info.shape == 2) {  /* sphere */
    circle("xy", 0, 0, 0, radius);
    circle("xz", 0, 0, 0, radius);
    circle("yz", 0, 0, 0, radius);
  }
%}

END
